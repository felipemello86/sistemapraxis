# Banco Postgres novo (não reaproveitar o da v1) — ex: Neon.
DATABASE_URL="postgresql://usuario:senha@host/banco?sslmode=require"

# String aleatória longa (ex: openssl rand -base64 32) — assina o cookie
# de sessão. Só precisa existir neste projeto Vercel (não precisa ser
# igual a nenhum secret da v1).
SESSION_SECRET="troque-por-uma-string-aleatoria-longa"

NEXT_PUBLIC_APP_URL="http://localhost:3100"

# Autentica o cron do AI Engine (api/cron/ai-engine) — mesmo padrão dos
# crons de apps/maintenance e apps/housekeeping. Gere uma string aleatória
# e configure o MESMO valor no header "Authorization: Bearer <valor>" do
# cron job na Vercel.
CRON_SECRET="troque-por-uma-string-aleatoria"

# Opcional — sem isso, os insights da Central de Inteligência seguem
# funcionando normalmente, só que com o texto tal como o detector escreveu
# (ver packages/ai-engine/src/narrator.ts: o LLM só reescreve a explicação
# em linguagem mais natural, nunca prioridade/confiança/evidência).
ANTHROPIC_API_KEY=""

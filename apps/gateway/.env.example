# Banco Postgres novo (não reaproveitar o da v1) — ex: Neon.
DATABASE_URL="postgresql://usuario:senha@host/banco?sslmode=require"

# String aleatória longa (ex: openssl rand -base64 32) — assina o cookie
# de sessão. Só precisa existir neste projeto Vercel (não precisa ser
# igual a nenhum secret da v1).
SESSION_SECRET="troque-por-uma-string-aleatoria-longa"

NEXT_PUBLIC_APP_URL="http://localhost:3100"

// Schema suite_core — identidade e licenciamento por módulo da suíte Praxis.
//
// Diferença crítica em relação à v1 (../../../packages/suite-core e as 4
// cópias vendorizadas em apps/*/prisma/suite-core): este é o ÚNICO lugar
// onde "usuário" existe. Nenhum app desta v2 deve ter sua própria tabela
// User local — todo dado operacional de qualquer módulo referencia
// User.id diretamente. Foi a mistura de dois espaços de id (local vs.
// suite_core) que causou a maior parte dos bugs de produção da v1.
//
// binaryTargets lista os alvos de forma EXPLÍCITA (não só "native") porque
// "native" resolve pra plataforma de quem RODA `prisma generate`, não de
// quem RODA o app — isso já mordeu tanto a v1 (faltava rhel-openssl-3.0.x
// pra Vercel) quanto a v2 (client gerado num sandbox Linux não tinha o
// engine pra Mac). Com os 3 alvos fixos, `prisma generate` sempre produz
// os binários certos pra dev local (Mac), dev/CI Linux, e produção Vercel.

generator client {
  provider        = "prisma-client-js"
  output          = "../generated"
  binaryTargets   = ["native", "rhel-openssl-3.0.x", "darwin-arm64"]
  // Habilitado depois de medir direto contra o banco de produção: queries
  // com várias relações (ex: Review em tratamento/page.tsx, 8 relações)
  // sem isso viram ~10 idas separadas ao Neon, uma por relação — 740ms a
  // 1.4s mesmo com poucas dezenas de linhas, porque o custo é dominado por
  // latência de rede (round-trip), não pelo trabalho do Postgres em si.
  // Com relationJoins + `relationLoadStrategy: "join"` na query, vira 1
  // query só com LEFT JOIN: 76-237ms na mesma massa de dados (>10x mais
  // rápido). Rode `npx prisma generate` de novo depois de puxar essa
  // mudança (mesmo passo manual de sempre, client não regenera no sandbox).
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Neon: DATABASE_URL usa o endpoint com pooler (pgbouncer) pro runtime da
  // aplicação; migrações precisam de conexão direta (sem pooler), senão
  // falham por causa de prepared statements que o pgbouncer não suporta.
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  modules TenantModule[]
  users   User[]

  // Governança (Housekeeping)
  hkConfig            HkConfig?
  inspectionTemplates InspectionTemplate[]
  properties          Property[]
  uhs                 UH[]
  cleaningPrograms    CleaningProgram[]
  falhasLavanderia    FalhaLavanderia[]
  guestComplaints     GuestComplaint[]
  geoArrivals         GeoArrival[]

  // Avaliações (Booking-Reviews)
  reviewsConfig        ReviewsConfig?
  reviewCategories     Category[]
  reviews              Review[]
  reviewCollectionRuns CollectionRun[]
  reviewAlerts         Alert[]
  pendingAirbnbImports PendingAirbnbImport[]
  performanceMeetings  PerformanceMeeting[]

  // Manutenção (Upkeep)
  maintenanceChecklistItems      MaintenanceChecklistItem[]
  maintenanceInspections         MaintenanceInspection[]
  maintenanceCorrections         MaintenanceCorrection[]
  maintenanceUnitChecklistItems  MaintenanceUnitChecklistItem[]
  maintenanceConfig              MaintenanceConfig?
  maintenanceUhImages            MaintenanceUhImage[]
  maintenanceUhSpots             MaintenanceUhSpot[]
  maintenanceItemInfos           MaintenanceItemInfo[]
  maintenanceItemInfoLogs        MaintenanceItemInfoLog[]

  // Estoque (módulo novo, migrado de um sistema Flask/Postgres avulso —
  // "estoque-bnb-flex" — que rodava fora da suíte, no Render).
  stockProducts   StockProduct[]
  stockMovements  StockMovement[]

  // Restaurante
  menuSections    MenuSection[]
  menuItems       MenuItem[]
  breakfastOrders BreakfastOrder[]
}

enum SuiteModule {
  HOUSEKEEPING
  MAINTENANCE
  BOOKING_REVIEWS
  RESTAURANT
  STOCK
}

// Licenciamento por módulo: um tenant só enxerga um módulo se houver uma
// linha aqui com enabled = true. Independente do acesso individual por
// usuário (ver UserModuleAccess) — as duas checagens precisam passar.
model TenantModule {
  id       String      @id @default(cuid())
  tenantId String
  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  module   SuiteModule
  enabled  Boolean     @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, module])
}

model User {
  id             String  @id @default(cuid())
  tenantId       String
  tenant         Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  nome           String
  email          String
  passwordHash   String?
  role           String // MASTER, GERENTE, GOVERNANTA, CAMAREIRA, LAVANDERIA, MANUTENCAO, ATENDIMENTO
  ativo          Boolean @default(true)
  telegramChatId String?
  whatsapp       String?
  // URL da foto de perfil (Cloudinary, upload feito na tela de Cadastro de
  // Usuários do gateway). Usada nos avatares de Tempo Real, Atribuição
  // Diária, Performance e Relatórios — todos já caem pra iniciais quando null.
  foto           String?
  // Atributo (não role): habilita o usuário a operar o kanban do módulo
  // Restaurante (mover cartões de pedido). É ortogonal ao cargo — uma
  // camareira ou um usuário de lavanderia podem ter cozinha=true.
  cozinha        Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  moduleAccess UserModuleAccess[]

  // Relações do módulo Governança (Housekeeping) — na v1 esses campos
  // apontavam pra um User LOCAL do app housekeeping (tabela duplicada,
  // id diferente do suite_core). Aqui é o mesmo User de sempre, com FK de
  // verdade — não tem mais espaço pra "local id vs suite_core id" divergir.
  hkAssignments      DailyAssignment[]   @relation("HkCamareira")
  hkCleaningSessions CleaningSession[]   @relation("HkCamareira")
  hkInspections      InspectionSession[] @relation("HkGovernanta")
  hkPushTokens       PushToken[]
  hkGeoArrivals      GeoArrival[]

  // Queixas de hóspede (ver GuestComplaint) — quem registrou (Atendimento)
  // e, separadamente, a camareira penalizada quando a queixa é de Limpeza.
  complaintsRegistradas GuestComplaint[] @relation("ComplaintRegisteredBy")
  complaintsComoCamareira GuestComplaint[] @relation("ComplaintCamareira")

  // Relações do módulo Avaliações (Booking-Reviews) — mesmo raciocínio: FK
  // real pro User único, sem User local duplicado (v1 tinha um User próprio
  // deste app, sincronizado por upsert best-effort a cada login — mesmo
  // padrão de bug já corrigido em Governança).
  reviewsAnalyzed       Review[]           @relation("ReviewAnalyzedBy")
  reviewActionItemsDone ActionItem[]       @relation("ReviewActionItemCompletedBy")
  reviewCollectionRuns  CollectionRun[]    @relation("ReviewCollectionRunTriggeredBy")
  reviewAttendantScores ReviewAttendant[]  @relation("ReviewAttendantOnReview")
  reviewManagerialNotes ManagerialNote[]
  reviewAttachments     ReviewAttachment[]
  reviewLogs            ReviewLog[]

  // Reuniões de Performance (ver bloco de models no fim do arquivo).
  coordinatedMeetings   PerformanceMeeting[]            @relation("MeetingCoordinator")
  createdMeetings       PerformanceMeeting[]            @relation("MeetingCreatedBy")
  meetingParticipations PerformanceMeetingParticipant[]
  meetingNotes          PerformanceMeetingNote[]
  meetingAttachments    PerformanceMeetingAttachment[]
  meetingLogs           PerformanceMeetingLog[]

  // Manutenção (Upkeep) — inspetor que realizou a inspeção (opcional: a v1
  // permite registrar sem inspetor definido).
  maintenanceInspections MaintenanceInspection[] @relation("MaintenanceInspector")

  // Manutenção (Upkeep) — autor da correção (opcional, mesmo motivo acima).
  maintenanceCorrections MaintenanceCorrection[] @relation("MaintenanceCorrectionAuthor")

  // Manutenção (Upkeep) — quem editou por último as "Informações do item"
  // (IV-UH) e quem é o autor de cada alteração no log correspondente.
  maintenanceItemInfoUpdates MaintenanceItemInfo[]    @relation("MaintenanceItemInfoUpdatedBy")
  maintenanceItemInfoLogs    MaintenanceItemInfoLog[] @relation("MaintenanceItemInfoLogAuthor")

  // Estoque — usuário que registrou a movimentação (opcional: dado migrado
  // do sistema antigo não tem FK real, ver comentário em StockMovement).
  stockMovements StockMovement[]

  // Constraint real — a v1 declarava isso no schema mas uma checagem
  // direta no Postgres de produção mostrou que ela nunca foi de fato
  // criada (schema drift), o que permitiu contas duplicadas silenciosas.
  // Aqui a migração inicial já cria de verdade.
  @@unique([tenantId, email])
}

// Acesso por módulo, por pessoa — independente do cargo. Uma GOVERNANTA
// pode não ter acesso a MAINTENANCE, por exemplo. `enabled = true` aqui E
// TenantModule.enabled = true pro mesmo módulo, as duas precisam ser
// verdadeiras.
model UserModuleAccess {
  id      String      @id @default(cuid())
  userId  String
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  module  SuiteModule
  enabled Boolean     @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, module])
}

// ═══════════════════════════════════════════════════════════════════════════
// GOVERNANÇA (Housekeeping) — domínio de negócio do primeiro módulo portado.
//
// Vindo de apps/housekeeping/prisma/schema.prisma (v1), adaptado: não existe
// mais model Hotel nem model User locais — "Hotel" era 1:1 com Tenant (só
// existia pra guardar um tenantId "solto", sem FK de verdade) e o User local
// duplicava o cadastro do suite_core. Tudo aqui referencia Tenant.id e
// User.id diretamente. hotelId virou tenantId, camareiraId/governantaId
// continuam com esse nome (papel na operação), mas apontam pro User único.
// ═══════════════════════════════════════════════════════════════════════════

model HkConfig {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  notificationTime  String @default("08:00")
  targetMinutes     Int    @default(25)
  photoRequirements String @default("[\"cozinha\",\"cama\",\"toalhas\",\"banheiro\"]")

  // Retaguarda do "relógio de disponibilidade" usado no score (ver
  // api/scores/route.ts): pra fechar a brecha de camareira atrasar
  // propositalmente o "iniciar" pra esconder tempo já trabalhado, o score
  // passa a contar a partir de max(UH liberada, fim da UH anterior do dia,
  // início do turno) em vez de simplesmente iniciadaEm. turnoInicioHora é
  // só o piso do dia — sem ele, a 1ª UH liberada de madrugada penalizaria
  // quem ainda nem chegou.
  turnoInicioHora String @default("08:00")
}

model InspectionTemplate {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  categoria String // CAMA | BANHEIRO | QUARTO | COZINHA | GERAL
  item      String
  ordem     Int
  ativo     Boolean @default(true)
}

model PushToken {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  token    String @unique
  platform String // "ios" | "android"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// Propriedade = agrupamento de UHs (ex: "Bnb Flex Suites", "Bnb Flex Comfort",
// "Bnb Flex Premium" — prédios/empreendimentos diferentes da mesma operação,
// cada um com seu próprio grupo de UHs). Cadastro centralizado no gateway,
// igual UH. Existe porque as notificações de avaliação (Booking/Airbnb) só
// identificam a propriedade/anúncio — nunca a UH específica onde o hóspede
// ficou — então Review se associa a Property, não a UH (ver model Review na
// seção AVALIAÇÕES mais abaixo; descoberto só depois de rodar a coleta real
// do Airbnb em produção e ver que o e-mail manda "Bnb Flex Suites", não
// "201-V").
model Property {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  nome String // ex: "Bnb Flex Suites"

  // Georreferenciamento (Governança) — coordenada do PRÉDIO, não da UH: GPS
  // não distingue andar/unidade dentro do mesmo prédio, então uma coordenada
  // por Property já é o nível real de precisão possível. Opcionais/nullable
  // de propósito — sem coordenada cadastrada, o check-in de chegada (ver
  // GeoArrival) simplesmente não roda pra essa property, e o score degrada
  // pro comportamento anterior (âncora só por "fim da UH anterior").
  latitude  Float?
  longitude Float?

  uhs         UH[]
  reviews     Review[]
  geoArrivals GeoArrival[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, nome])
}

// Confirmação de presença física da camareira num prédio (Property), via
// GPS do aparelho — insumo do "relógio de disponibilidade" em
// api/scores/route.ts (housekeeping). Só existe UMA linha por
// (camareira, property, dia): é a PRIMEIRA vez que o app confirmou ela
// dentro do raio de tolerância (ver POST /api/geo/checkin) — upsert com
// update:{} garante isso (nunca sobrescreve pra uma chegada mais tarde).
//
// Por que Property e não UH: dentro do mesmo prédio o GPS não diferencia
// unidades, então a chegada vale pra QUALQUER UH daquele prédio atribuída
// à camareira naquele dia — não precisa de um check-in por UH.
model GeoArrival {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  data        String // YYYY-MM-DD
  camareiraId String
  camareira   User   @relation(fields: [camareiraId], references: [id], onDelete: Cascade)
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  chegadaEm       DateTime // primeira confirmação dentro do raio (ver HAVERSINE_RAIO_METROS em lib/geo.ts)
  distanciaMetros Float? // distância real no momento da confirmação — só auditoria/debug

  createdAt DateTime @default(now())

  @@unique([tenantId, data, camareiraId, propertyId])
}

model UH {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])

  numero String // ex: "101", "CHALÉ 3"
  tipo   String  @default("Standard")
  status String  @default("OCUPADO") // OCUPADO | DISPONIVEL | EM_LIMPEZA | AGUARDANDO_INSPECAO | PRONTO
  ativo  Boolean @default(true)
  ordem  Int     @default(0)

  emManutencao            Boolean   @default(false)
  manutencaoDescricao     String?
  bloqueada               Boolean   @default(false)
  bloqueioDescricao       String?
  bloqueioSolicitanteNome String?
  bloqueioEm              DateTime?

  assignments      DailyAssignment[]
  cleaningSessions CleaningSession[]
  inspections      InspectionSession[]
  selecoes         DailyUHSelection[]
  guestComplaints  GuestComplaint[]

  // Manutenção (Upkeep) — cadastro de UH continua centralizado aqui (gateway),
  // o módulo Manutenção referencia via FK em vez de ter seu próprio model
  // "Unit" duplicado (era assim na v1 — mesmo problema de duplicação de
  // usuário que já foi corrigido em todo o resto da suíte).
  maintenanceInspections        MaintenanceInspection[]
  maintenanceCorrections        MaintenanceCorrection[]
  maintenanceUnitChecklistItems MaintenanceUnitChecklistItem[]
  maintenanceUhImages           MaintenanceUhImage[]
  maintenanceItemInfos          MaintenanceItemInfo[]
  maintenanceItemInfoLogs       MaintenanceItemInfoLog[]

  @@unique([tenantId, numero])
}

model DailyUHSelection {
  id              String    @id @default(cuid())
  tenantId        String
  data            String // YYYY-MM-DD
  uhId            String
  uh              UH        @relation(fields: [uhId], references: [id], onDelete: Cascade)
  liberada        Boolean   @default(false)
  liberadaEm      DateTime?
  liberadoPorNome String?
  temReserva      Boolean   @default(false)

  // Comentário livre na UH, independente de ter camareira atribuída (ao
  // contrário de DailyAssignment.observacoes, que é uma orientação pra
  // camareira e exige assignmentId). Restrito a MASTER/GERENTE/ATENDIMENTO
  // na tela — ver apps/housekeeping/src/app/api/selecao-uhs/route.ts.
  comentario       String?
  comentarioPorNome String?
  comentarioEm      DateTime?

  // Late Check-out — o Atendimento marca que esta UH só vai ser liberada
  // mais tarde (hóspede com late checkout autorizado), com hora de saída
  // obrigatória ("HH:mm"). Quando essa hora chega, o sistema libera a UH
  // sozinho (ver lib/late-checkout.ts) — chamado como efeito colateral no
  // GET de Seleção e Liberação e do Tempo Real, e também por um cron
  // dedicado (api/cron/late-checkout), pra funcionar mesmo sem ninguém com
  // uma tela aberta.
  lateCheckout        Boolean   @default(false)
  lateCheckoutHora     String?
  lateCheckoutPorNome  String?
  lateCheckoutEm       DateTime?

  @@unique([data, uhId])
}

model CoberturaFolga {
  id           String   @id @default(cuid())
  tenantId     String
  data         String // YYYY-MM-DD (dia da folga)
  governantaId String
  substitutaId String
  createdAt    DateTime @default(now())

  @@unique([tenantId, data])
}

model DailySelectionStatus {
  id         String  @id @default(cuid())
  tenantId   String
  data       String
  confirmado Boolean @default(false)

  @@unique([tenantId, data])
}

// Fecho oficial do dia (fluxo "Finalização do Dia") — distinto de
// DailySelectionStatus.confirmado, que é a confirmação da SELEÇÃO de UHs
// feita de manhã pelo Atendimento/Gerente. Este aqui marca que a governanta
// já revisou o ranking do dia (podendo excluir UHs pontuais do score, com
// justificativa — ver CleaningSession.excluidoDoScore/justificativaExclusao)
// e confirmou o fechamento, disparando o push de "dia finalizado" pra todo
// mundo. Ver apps/housekeeping/src/app/api/finalizacao-dia/route.ts.
model DailyClosure {
  id                String   @id @default(cuid())
  tenantId          String
  data              String // YYYY-MM-DD
  finalizadoEm      DateTime @default(now())
  finalizadoPorNome String

  @@unique([tenantId, data])
}

model CleaningProgram {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  nome  String
  tipo  String  @default("ARRUMACAO") // ARRUMACAO | LIMPEZA_COMPLETA | SUPER_LIMPEZA
  ativo Boolean @default(true)

  steps       ProgramStep[]
  assignments DailyAssignment[]
}

model ProgramStep {
  id        String          @id @default(cuid())
  programId String
  program   CleaningProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  ordem     Int
  titulo    String
  descricao String?

  sessionSteps SessionStep[]
}

model DailyAssignment {
  id          String           @id @default(cuid())
  tenantId    String
  data        String // YYYY-MM-DD
  uhId        String
  uh          UH               @relation(fields: [uhId], references: [id], onDelete: Cascade)
  camareiraId String
  camareira   User             @relation("HkCamareira", fields: [camareiraId], references: [id], onDelete: Cascade)
  programId   String?
  program     CleaningProgram? @relation(fields: [programId], references: [id])

  status              String    @default("PENDENTE") // PENDENTE | LIBERADO | EM_ANDAMENTO | CONCLUIDO | INSPECIONADO
  liberadaEm          DateTime?
  criadoPorNome       String?
  observacoes         String?
  solicitacaoMensagem String?
  solicitacaoStatus   String? // null | PENDENTE | APROVADO | REJEITADO
  // Tipo da solicitação em curso (só é relevante enquanto solicitacaoStatus
  // não for null) — distingue a troca-pra-limpeza-completa original da
  // Super Limpeza ⭐️ (pedido da camareira, com fotos, que a governanta
  // aprova/indefere; some 120 pts fixos sem monitoramento de tempo, só com
  // desconto de -10/falha na inspeção — ver src/lib/scoring.ts). Null nas
  // solicitações antigas == TROCA_PROGRAMA, pra não quebrar dado existente.
  solicitacaoTipo  String? // TROCA_PROGRAMA | SUPER_LIMPEZA
  solicitacaoFotos String  @default("[]") // JSON array de URLs (Cloudinary) — opcional, só usado em SUPER_LIMPEZA

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cleaningSession CleaningSession?

  // Relaxado de @@unique([data, uhId]) — agora é possível ter mais de uma
  // DailyAssignment (uma por camareira) pra mesma UH no mesmo dia, pra
  // suportar "Super Limpeza a duas" / mutirão. Quando há >1 linha pra o
  // mesmo (data, uhId), NINGUÉM pontua por aquela UH naquele dia (checado
  // dinamicamente em api/scores/route.ts, não persistido aqui).
  @@unique([data, uhId, camareiraId])
}

model CleaningSession {
  id           String          @id @default(cuid())
  assignmentId String          @unique
  assignment   DailyAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  uhId         String
  uh           UH              @relation(fields: [uhId], references: [id], onDelete: Cascade)
  camareiraId  String
  camareira    User            @relation("HkCamareira", fields: [camareiraId], references: [id], onDelete: Cascade)

  iniciadaEm      DateTime
  finalizadaEm    DateTime?
  duracaoSegundos Int?
  fotos           String    @default("[]") // JSON: { [tipo]: string[] } (Cloudinary) — apesar do nome/default, nunca foi de fato um array desde que passou a existir mais de um tipo de foto obrigatória; o default "[]" só é o estado inicial antes da 1ª foto.
  observacoes     String?

  // Rastro da última edição de fotos feita pela camareira depois de já ter
  // concluído a UH (ver "Editar fotos" em Minhas UHs) — mesmo padrão
  // "timestamp + nome" já usado em DailyUHSelection (liberadaEm/
  // liberadoPorNome, comentarioEm/comentarioPorNome): só guarda a ÚLTIMA
  // edição, não um histórico completo. Usado por /api/logs pra gerar o
  // evento FOTOS_EDITADAS no Log do Sistema.
  fotosEditadasEm      DateTime?
  fotosEditadasPorNome String?

  comentarioCamareira   String?
  excluidoDoScore       Boolean @default(false)
  justificativaExclusao String?

  // Etapa obrigatória "Necessidade de Manutenção?", inserida entre o
  // checklist e as fotos de conclusão — ver CamareiraView, fase
  // "manutencao". O tempo gasto nela (registrar item(ns) não conforme(s)
  // pra Manutenção) não deve contar contra a camareira: manutencaoAbertaEm
  // marca quando ela entrou na etapa; ao sair (respondeu "Não" à pergunta,
  // ou terminou o loop de registrar itens), o delta é somado em
  // manutencaoSegundosExcluidos e subtraído de duracaoSegundos no
  // "finalizar" (ver /api/sessoes).
  manutencaoAbertaEm          DateTime?
  manutencaoSegundosExcluidos Int       @default(0)

  createdAt DateTime @default(now())

  steps      SessionStep[]
  inspection InspectionSession?
}

model SessionStep {
  id              String          @id @default(cuid())
  sessionId       String
  session         CleaningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  stepId          String
  step            ProgramStep     @relation(fields: [stepId], references: [id])
  ordem           Int
  iniciadoEm      DateTime
  finalizadoEm    DateTime?
  duracaoSegundos Int?
}

model InspectionSession {
  id           String          @id @default(cuid())
  sessionId    String          @unique
  session      CleaningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  uhId         String
  uh           UH              @relation(fields: [uhId], references: [id], onDelete: Cascade)
  governantaId String
  governanta   User            @relation("HkGovernanta", fields: [governantaId], references: [id], onDelete: Cascade)

  iniciadaEm            DateTime
  finalizadaEm          DateTime?
  totalFalhas           Int       @default(0) // conta apenas falhas tipo CAMAREIRA
  totalFalhasGerenciais Int       @default(0)
  comentarioGovernanta  String?
  observacoes           String?

  createdAt DateTime @default(now())

  itens InspectionItem[]
}

model InspectionItem {
  id           String            @id @default(cuid())
  inspectionId String
  inspection   InspectionSession @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  categoria    String // CAMA | BANHEIRO | QUARTO | COZINHA | GERAL
  item         String
  ordem        Int
  resultado    String            @default("OK") // OK | FALHA | NAO_APLICAVEL
  tipoFalha    String            @default("CAMAREIRA") // CAMAREIRA | GERENCIAL
  observacao   String?
}

model FalhaLavanderia {
  id               String   @id @default(cuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  data             String // YYYY-MM-DD
  uhNumero         String
  descricao        String
  reportadoPorNome String
  reportadoPorRole String // CAMAREIRA | GOVERNANTA
  fotoUrl          String?
  createdAt        DateTime @default(now())
}

// Queixa de hóspede registrada pelo Atendimento na tela Seleção e Liberação
// (Governança) — o hóspede reclamou de algo relacionado à UH do dia. Duas
// consequências automáticas (ver api/selecao-uhs/route.ts, ação
// "registrar_queixa"):
//   1. Sempre cria um card espelho em Avaliações (Review, platform=INTERNO),
//      tratado pela GERENTE dentro do fluxo normal do Kanban de Tratamento
//      — entra em RECEBIDA como qualquer avaliação, com nota fixa baixa
//      (1 estrela) contando na média do dashboard.
//   2. Se tipo=LIMPEZA e havia exatamente uma camareira atribuída à UH
//      naquele dia, desconta pontosDescontados (fixo 30) do total dela no
//      período — penalidade independente, somada em api/scores/route.ts,
//      não depende de existir sessão de limpeza concluída naquele dia. Nos
//      demais tipos (MANUTENCAO, LAVANDERIA, OUTRA) não há desconto — em vez
//      disso dispara alerta Telegram pra GERENTE + o cargo correspondente
//      (MANUTENCAO→role MANUTENCAO, LAVANDERIA→role LAVANDERIA, OUTRA→só
//      GERENTE, ver lib/telegram.ts).
model GuestComplaint {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  data String // YYYY-MM-DD — dia do cartão em que a queixa foi registrada
  uhId String
  uh   UH     @relation(fields: [uhId], references: [id], onDelete: Cascade)

  // Preenchido obrigatoriamente na abertura da queixa — é o mesmo texto
  // usado como Review.guestName do card espelho (ver abaixo), já que é ele
  // que aparece como título no Kanban de Tratamento de Avaliações.
  titulo    String
  tipo      String // LIMPEZA | MANUTENCAO | LAVANDERIA | OUTRA
  descricao String @db.Text
  // JSON array de { url, fileName, fileSize } (Cloudinary, resource_type
  // "auto" — aceita foto, PDF etc.) — anexo opcional de evidência. Os mesmos
  // arquivos também viram ReviewAttachment no card espelho (ver review
  // abaixo), pra a GERENTE já ver tudo dentro do fluxo de Avaliações.
  anexos String @default("[]")

  registradoPorId   String
  registradoPor     User   @relation("ComplaintRegisteredBy", fields: [registradoPorId], references: [id])
  registradoPorNome String

  // Só preenchido quando tipo=LIMPEZA e havia exatamente uma camareira
  // atribuída à UH naquele dia — é quem recebe o desconto.
  camareiraId       String?
  camareira         User?   @relation("ComplaintCamareira", fields: [camareiraId], references: [id])
  pontosDescontados Int?

  // Card espelho criado automaticamente em Avaliações.
  reviewId String? @unique
  review   Review? @relation(fields: [reviewId], references: [id])

  createdAt DateTime @default(now())

  @@index([tenantId, data, uhId])
  @@index([tenantId, camareiraId])
}

// ═══════════════════════════════════════════════════════════════════════════
// AVALIAÇÕES (Booking-Reviews) — gestão/tratativa de avaliações já publicadas
// no Booking.com e Airbnb (não é pesquisa de satisfação preenchida pelo
// hóspede — o hóspede nunca interage com este sistema).
//
// Vindo de apps/booking-reviews/prisma/schema.prisma (v1), com as mesmas
// correções estruturais já aplicadas em Governança:
//   - Não existe mais model `Company` — era uma tabela paralela a Tenant,
//     ligada só por um `tenantId String? @unique` solto, sem FK real.
//   - Não existe mais model `User` local — era sincronizado por upsert
//     best-effort a cada login (mesmo padrão de bug já corrigido).
//   - O `Property` do v1 tinha id solto, sem FK real pra nada (era resolvido
//     por match de texto contra o nome extraído do e-mail/digitado
//     manualmente). Aqui `Property` é um model de primeira classe do
//     gateway (ver acima, junto de UH) — Review.propertyId é FK de verdade.
//     IMPORTANTE: Review associa a Property, não a UH — Booking/Airbnb só
//     informam a propriedade/anúncio na notificação, nunca a UH específica.
//   - `Role` (enum local do v1, com o par legado ATENDENTE/ATENDIMENTO) não
//     existe mais — usa o `role: String` do User compartilhado, como todo
//     resto da suíte.
//   - `ReworkRequest` (v1) não foi portado — já estava marcado como legado
//     no código do v1, substituído pelo fluxo `reopenAnalysisAction`
//     (reabertura direta do card, sem aprovação em separado).
//   - Módulo "Reuniões de Performance" (PerformanceMeeting e afins) tem
//     schema próprio, sem dependência do domínio de avaliações abaixo — ver
//     bloco de models no fim do arquivo.
// ═══════════════════════════════════════════════════════════════════════════

enum ReviewPlatform {
  BOOKING
  AIRBNB
  // Card criado automaticamente a partir de uma queixa de hóspede registrada
  // pelo Atendimento em Governança (ver GuestComplaint) — não veio de OTA.
  INTERNO
}

enum ReviewStage {
  RECEBIDA
  ANALISE_PLANEJAMENTO
  EXECUCAO
  AVALIACAO_EFICACIA
  FINALIZADA
}

enum ReviewAlertChannel {
  EMAIL
  WHATSAPP
  TELEGRAM
}

enum ReviewAlertType {
  COLETA_NAO_REALIZADA
  ANALISE_NAO_REALIZADA
  ACAO_VENCIDA
  ANALISE_PLANEJAMENTO_CONCLUIDA
  EXECUCAO_CONCLUIDA
  DATA_EFICACIA_CHEGOU
  CARD_FINALIZADO
  AVALIACAO_ATENDIMENTO_RECEBIDA
  PLANEJAMENTO_REABERTO
  CARD_EXCLUIDO
  PROPRIEDADE_PENDENTE
  PLANEJAMENTO_REJEITADO
}

model ReviewsConfig {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  targetScore Float @default(4.8) // "Valor Meta" do dashboard

  // Marca d'água da última avaliação do Airbnb já coletada via integração
  // automática (Microsoft Graph) — evita reimportar a mesma avaliação.
  airbnbLastCollectedAt DateTime?
}

model Category {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name   String // Limpeza, Manutenção, Atendimento, Check-in...
  active Boolean @default(true)

  reviews ReviewCategory[]

  @@unique([tenantId, name])
}

model Review {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Toda avaliação precisa estar associada a uma Property — obrigatório
  // tanto na coleta automática do Airbnb (se o e-mail não permitir extrair
  // a propriedade, o card fica pendente em PendingAirbnbImport até alguém
  // atribuir manualmente) quanto no cadastro manual da Booking. NÃO é FK
  // pra UH: Booking/Airbnb só identificam a propriedade/anúncio na
  // notificação (ex: "Bnb Flex Suites"), nunca a UH específica onde o
  // hóspede ficou — essa granularidade não existe na origem do dado.
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])

  platform  ReviewPlatform
  guestName String
  comment   String?        @db.Text

  ratingRaw        Float // nota como veio da OTA
  ratingScaleMax   Float @default(10) // Airbnb=5 (regra de três); Booking=10
  ratingNormalized Float // sempre em escala 0-5, calculada na ingestão

  checkInDate      DateTime?
  guestSubmittedAt DateTime // data em que a avaliação chegou na OTA (eixo do dashboard)
  collectedAt      DateTime  @default(now()) // data em que o sistema coletou

  stage          ReviewStage @default(RECEBIDA)
  skippedToFinal Boolean     @default(false) // nota alta movida direto pra Finalizadas

  analysisDueAt       DateTime? // prazo de 2 dias úteis para iniciar análise
  analyzedById        String?
  analyzedBy          User?     @relation("ReviewAnalyzedBy", fields: [analyzedById], references: [id])
  analysisCompletedAt DateTime?

  attendants      ReviewAttendant[]
  categories      ReviewCategory[]
  actionPlan      ActionPlan?
  efficacyChecks  EfficacyCheck[]
  managerialNotes ManagerialNote[]
  attachments     ReviewAttachment[]
  logs            ReviewLog[]

  // Presente só quando platform=INTERNO — o registro de origem em
  // Governança (ver GuestComplaint) que gerou este card.
  complaint GuestComplaint?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, guestSubmittedAt])
  @@index([tenantId, stage])
}

// Anexos livres (imagens, documentos etc) num card de avaliação — qualquer
// usuário autenticado pode subir (Cloudinary, mesmo padrão de fotos da
// camareira em Governança — só a referência fica no banco).
model ReviewAttachment {
  id           String   @id @default(cuid())
  reviewId     String
  review       Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  fileName     String
  fileUrl      String
  fileSize     Int?
  contentType  String?
  createdAt    DateTime @default(now())

  @@index([reviewId])
}

// Log automático (não editável por usuários) da história de tratativa de
// cada card — toda mudança relevante de estágio (iniciar análise, concluir
// análise, reabrir/rejeitar planejamento, concluir execução, finalizar etc)
// grava uma entrada aqui, visível a qualquer papel.
model ReviewLog {
  id        String   @id @default(cuid())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  actorId   String
  actor     User     @relation(fields: [actorId], references: [id])
  action    String
  detail    String?  @db.Text
  createdAt DateTime @default(now())

  @@index([reviewId])
}

model ReviewAttendant {
  id          String @id @default(cuid())
  reviewId    String
  review      Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  attendantId String
  attendant   User   @relation("ReviewAttendantOnReview", fields: [attendantId], references: [id])
  score       Float // 0 a 5 (estrelas)
  observation String @db.Text // obrigatório

  @@unique([reviewId, attendantId])
}

model ReviewCategory {
  id         String   @id @default(cuid())
  reviewId   String
  review     Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  @@unique([reviewId, categoryId])
}

model ActionPlan {
  id        String   @id @default(cuid())
  reviewId  String   @unique
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  items ActionItem[]
}

model ActionItem {
  id            String     @id @default(cuid())
  actionPlanId  String
  actionPlan    ActionPlan @relation(fields: [actionPlanId], references: [id], onDelete: Cascade)
  description   String
  dueDate       DateTime
  completedAt   DateTime?
  completedById String?
  completedBy   User?      @relation("ReviewActionItemCompletedBy", fields: [completedById], references: [id])

  @@index([dueDate])
  @@index([actionPlanId])
}

model EfficacyCheck {
  id            String    @id @default(cuid())
  reviewId      String
  review        Review    @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  scheduledDate DateTime
  description   String?   @db.Text
  completedAt   DateTime?
  wasEffective  Boolean?
  notes         String?   @db.Text

  @@index([scheduledDate])
  @@index([reviewId])
}

// Avaliação do Airbnb coletada automaticamente, mas cujo e-mail não permitiu
// extrair a UH (layout do e-mail mudou, nome não bateu com nenhuma UH
// cadastrada etc). Como UH é obrigatória em todo card, esses casos ficam
// aqui até um Gerente/Master atribuir a UH manualmente — só então viram um
// Review de verdade.
model PendingAirbnbImport {
  id               String    @id @default(cuid())
  tenantId         String
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  guestName        String
  ratingRaw        Float
  guestSubmittedAt DateTime
  checkInDate      DateTime?
  createdAt        DateTime  @default(now())

  @@index([tenantId])
}

model CollectionRun {
  id               String   @id @default(cuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  triggeredById    String
  triggeredBy      User     @relation("ReviewCollectionRunTriggeredBy", fields: [triggeredById], references: [id])
  triggeredAt      DateTime @default(now())
  status           String   @default("PENDING") // PENDING | DONE | FAILED
  reviewsCollected Int?
  notes            String?
}

model Alert {
  id            String             @id @default(cuid())
  tenantId      String
  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type          ReviewAlertType
  channel       ReviewAlertChannel
  message       String
  targetUserIds String[]
  reviewId      String?
  sentAt        DateTime           @default(now())
}

// Observações gerenciais: histórico de anotações livres num card, feitas por
// qualquer papel, visível em qualquer estágio do Kanban.
model ManagerialNote {
  id        String   @id @default(cuid())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  text      String   @db.Text
  createdAt DateTime @default(now())

  @@index([reviewId])
}

// Tela "Reuniões de Performance" — bloco de porte próprio (ver comentário no
// topo da seção AVALIAÇÕES), sem dependência do domínio de reviews acima:
// reunião com coordenador (único) e participantes (vários), observações e
// anexos livres (qualquer usuário) e um log automático de atividades. Criar
// reunião / definir coordenador e participantes é restrito a Master/Gerente.
// companyId (v1) → tenantId, mesma troca do resto do schema.
model PerformanceMeeting {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  date          DateTime // dia da reunião (mostrado no calendário)
  coordinatorId String
  coordinator   User     @relation("MeetingCoordinator", fields: [coordinatorId], references: [id])
  createdById   String
  createdBy     User     @relation("MeetingCreatedBy", fields: [createdById], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  participants PerformanceMeetingParticipant[]
  notes        PerformanceMeetingNote[]
  attachments  PerformanceMeetingAttachment[]
  logs         PerformanceMeetingLog[]

  @@index([tenantId, date])
}

model PerformanceMeetingParticipant {
  id        String             @id @default(cuid())
  meetingId String
  meeting   PerformanceMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId    String
  user      User               @relation(fields: [userId], references: [id])

  @@unique([meetingId, userId])
}

model PerformanceMeetingNote {
  id        String             @id @default(cuid())
  meetingId String
  meeting   PerformanceMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  authorId  String
  author    User               @relation(fields: [authorId], references: [id])
  text      String             @db.Text
  createdAt DateTime           @default(now())

  @@index([meetingId])
}

model PerformanceMeetingAttachment {
  id           String             @id @default(cuid())
  meetingId    String
  meeting      PerformanceMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User               @relation(fields: [uploadedById], references: [id])
  fileName     String
  fileUrl      String
  fileSize     Int?
  contentType  String?
  createdAt    DateTime           @default(now())

  @@index([meetingId])
}

// Histórico automático (não editável por usuários) do que aconteceu na
// reunião: criação, troca de coordenador, participantes adicionados/
// removidos, observação e anexo adicionados/removidos.
model PerformanceMeetingLog {
  id        String             @id @default(cuid())
  meetingId String
  meeting   PerformanceMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  actorId   String?
  actor     User?              @relation(fields: [actorId], references: [id])
  action    String
  detail    String?
  createdAt DateTime           @default(now())

  @@index([meetingId])
}

// ═══════════════════════════════════════════════════════════════════════════
// MANUTENÇÃO (Upkeep) — checklist de itens + inspeções periódicas por UH.
//
// Vindo de apps/maintenance (v1: um Express standalone com schema Postgres
// próprio "maintenance", multiSchema, ligado a Tenant só por valor de id —
// sem FK real — mais um frontend Next.js parcialmente migrado). Descartado
// nesse port, por decisão explícita: toda a infra de SaaS do backend antigo
// (Stripe/planos, hotsite público, painel admin, e-mail via Resend, cron de
// WhatsApp via Twilio) — nunca chegou a ser usada de verdade. O compartilhar
// manual de rota via wa.me (RotaManutencao) é client-side puro e não depende
// de nada disso, então foi mantido.
//
// Duas simplificações em relação à v1, mesma filosofia do resto da suíte:
//   - Sem model "Unit" próprio — reaproveita o UH já centralizado no gateway
//     (ver comentário em UH.maintenanceInspections acima).
//   - checklistItemId é FK de verdade pro catálogo (onDelete: SetNull), no
//     lugar do "itemLegacyId" solto (Int, sem FK) que a v1 usava só porque
//     tinha nascido de um schema legado sem cuid — aqui não tem esse motivo.
//   - UPDATE 2026-07: recuperando funcionalidades do protótipo standalone
//     "Bnb Manutenção" (sistema-manutencao.html) que não tinham sido
//     portadas na primeira leva — Rota de Correção, fotos na inspeção,
//     atribuição de item por UH e config de prazo/meta. Integração
//     WhatsApp daquele protótipo foi deliberadamente descartada (visão de
//     comunicação da v2 é push notification, não WhatsApp).
// ═══════════════════════════════════════════════════════════════════════════

model MaintenanceChecklistItem {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name           String
  category       String // texto livre (ex: "Elétrica", "Hidráulica") — sem lista fixa, igual v1
  subDescription String?

  inspectionItems  MaintenanceInspectionItem[]
  corrections      MaintenanceCorrection[]
  unitAssignments  MaintenanceUnitChecklistItem[]
  uhSpots          MaintenanceUhSpot[]
  itemInfos        MaintenanceItemInfo[]
  itemInfoLogs     MaintenanceItemInfoLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model MaintenanceInspection {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  uhId String
  uh   UH     @relation(fields: [uhId], references: [id], onDelete: Cascade)

  inspectorId String?
  inspector   User?   @relation("MaintenanceInspector", fields: [inspectorId], references: [id])

  date DateTime @default(now())

  items MaintenanceInspectionItem[]

  createdAt DateTime @default(now())

  @@index([tenantId, date])
  @@index([uhId])
}

model MaintenanceInspectionItem {
  id           String                @id @default(cuid())
  inspectionId String
  inspection   MaintenanceInspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  checklistItemId String?
  checklistItem   MaintenanceChecklistItem? @relation(fields: [checklistItemId], references: [id], onDelete: SetNull)

  status  String // CONFORME | NAO_CONFORME
  comment String?
  photos  String  @default("[]") // JSON array de URLs (Cloudinary) — evidência de não conformidade

  // Preenchido quando uma MaintenanceCorrection resolve este item (o status
  // acima volta pra CONFORME e este campo guarda quando isso aconteceu —
  // mesmo comportamento do REGISTER_CORRECAO do protótipo standalone).
  corrigidoEm DateTime?

  corrections MaintenanceCorrection[]

  @@index([inspectionId])
}

// Rota de Correção — fluxo dedicado pra encerrar uma não-conformidade
// registrada numa inspeção: técnico descreve o reparo (+ foto opcional),
// o item correspondente vira CONFORME e fica um histórico permanente.
// Recuperado do protótipo standalone "Bnb Manutenção" (REGISTER_CORRECAO /
// PageCorrecao), que não tinha sido portado na primeira leva da v2.
model MaintenanceCorrection {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  inspectionItemId String
  inspectionItem    MaintenanceInspectionItem @relation(fields: [inspectionItemId], references: [id], onDelete: Cascade)

  uhId String
  uh   UH     @relation(fields: [uhId], references: [id], onDelete: Cascade)

  checklistItemId String?
  checklistItem   MaintenanceChecklistItem? @relation(fields: [checklistItemId], references: [id], onDelete: SetNull)

  authorId String?
  author   User?   @relation("MaintenanceCorrectionAuthor", fields: [authorId], references: [id])

  description String  @db.Text
  photos      String  @default("[]") // JSON array de URLs (Cloudinary)

  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([inspectionItemId])
  @@index([uhId])
}

// Atribuição de item de checklist por UH. Ausência de linhas pra uma UH
// significa "todos os itens do catálogo se aplicam" (default retrocompatível
// com o comportamento atual, onde todo item vale pra toda UH) — a tabela só
// funciona como restrição quando alguém explicitamente monta uma lista
// customizada pra uma UH em Configurações.
model MaintenanceUnitChecklistItem {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  uhId String
  uh   UH     @relation(fields: [uhId], references: [id], onDelete: Cascade)

  checklistItemId String
  checklistItem   MaintenanceChecklistItem @relation(fields: [checklistItemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([uhId, checklistItemId])
  @@index([tenantId])
}

// "Informações do item" (IV-UH, no vocabulário do Felipe: Item de
// Verificação x UH) — dado cadastral livre por UH x item de checklist, ex.:
// ar-condicionado → potência, fabricante, número de série. Separado de
// MaintenanceUnitChecklistItem de propósito: aquele model é a atribuição
// (quais itens se aplicam à UH — ausência de linha = todos se aplicam, ver
// comentário logo acima e itensParaUnidade em lib/domain.ts); reaproveitar a
// mesma tabela pra guardar texto livre criaria linhas "fantasma" que
// mudariam sem querer a atribuição de UHs que nunca tiveram restrição
// nenhuma. Editável em UH 3D e nas telas de item não conforme (Inspeções,
// Rota de Correção) — toda alteração gera uma linha em
// MaintenanceItemInfoLog (nunca apagada).
model MaintenanceItemInfo {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  uhId String
  uh   UH     @relation(fields: [uhId], references: [id], onDelete: Cascade)

  checklistItemId String
  checklistItem   MaintenanceChecklistItem @relation(fields: [checklistItemId], references: [id], onDelete: Cascade)

  info   String? @db.Text
  photos String  @default("[]") // JSON array de URLs (Cloudinary)

  updatedById String?
  updatedBy   User?   @relation("MaintenanceItemInfoUpdatedBy", fields: [updatedById], references: [id])

  updatedAt DateTime @updatedAt

  logs MaintenanceItemInfoLog[]

  @@unique([uhId, checklistItemId])
  @@index([tenantId])
}

model MaintenanceItemInfoLog {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  itemInfoId String
  itemInfo   MaintenanceItemInfo @relation(fields: [itemInfoId], references: [id], onDelete: Cascade)

  uhId String
  uh   UH     @relation(fields: [uhId], references: [id], onDelete: Cascade)

  checklistItemId String
  checklistItem   MaintenanceChecklistItem @relation(fields: [checklistItemId], references: [id], onDelete: Cascade)

  previousInfo String? @db.Text
  newInfo      String? @db.Text

  previousPhotos String @default("[]") // JSON array de URLs (Cloudinary)
  newPhotos      String @default("[]") // JSON array de URLs (Cloudinary)

  authorId String?
  author   User?   @relation("MaintenanceItemInfoLogAuthor", fields: [authorId], references: [id])

  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([itemInfoId])
  @@index([uhId])
}

// Config por tenant — prazo máximo entre inspeções (usado em Controle de
// Inspeções e na priorização da Rota de Manutenção) e meta de conformidade
// (usada na Visão Gerencial). Mesmo padrão de HkConfig (Governança).
model MaintenanceConfig {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  maxDaysBetweenInspections Int @default(90)
  goal                      Int @default(90) // meta de conformidade, em %

  updatedAt DateTime @updatedAt
}

// Tela "UH 3D" — visão imersiva por cômodo (porta/quarto/cozinha/banheiro)
// com spots de verificação sobrepostos às fotos. Cadastro é por UH
// individual (não por "tipo de UH" — decisão explícita do Felipe: cada UH
// tem seu próprio conjunto de fotos, mesmo que o layout se repita entre
// unidades). `tipo` aqui é texto livre com valores esperados
// "porta" | "quarto" | "cozinha" | "banheiro" (constante ROOM_TYPES no
// front, não um enum no banco — mesmo padrão de category em
// MaintenanceChecklistItem, pra deixar margem de expandir os cômodos padrão
// no futuro sem migration).
model MaintenanceUhImage {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  uhId String
  uh   UH     @relation(fields: [uhId], references: [id], onDelete: Cascade)

  tipo     String // "porta" | "quarto" | "cozinha" | "banheiro" — cômodo padrão;
  // pode repetir (mais de uma foto por cômodo, ver comentário na migration
  // que removeu o @@unique original). Ordem de exibição = createdAt asc.
  imageUrl String // Cloudinary

  spots MaintenanceUhSpot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([uhId, tipo])
}

// Um spot = um item de checklist posicionado sobre uma MaintenanceUhImage
// (x/y em % relativo à imagem, 0-100, pra ficar responsivo em qualquer
// tamanho de tela). O mesmo item pode ter spot em mais de uma imagem da
// mesma UH (ex.: um item "Tomadas" pode aparecer tanto na foto do quarto
// quanto na da cozinha) — por isso não há @@unique em checklistItemId
// sozinho, só a combinação imagem+item não pode duplicar.
model MaintenanceUhSpot {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  imageId String
  image   MaintenanceUhImage @relation(fields: [imageId], references: [id], onDelete: Cascade)

  checklistItemId String
  checklistItem   MaintenanceChecklistItem @relation(fields: [checklistItemId], references: [id], onDelete: Cascade)

  x Float // 0-100, % da largura da imagem
  y Float // 0-100, % da altura da imagem

  createdAt DateTime @default(now())

  @@unique([imageId, checklistItemId])
  @@index([tenantId])
}

// ═══════════════════════════════════════════════════════════════════════════
// Estoque (módulo novo — apps/estoque)
//
// Migrado de um sistema Flask/Postgres avulso ("estoque-bnb-flex", Render)
// que rodava fora da suíte, sem tenant/login próprios (single-tenant, uso
// interno da BNB Flex). Schema aqui espelha o de lá (nome, categoria,
// unidade, quantidade, estoque mínimo, custo, fornecedor / tipo entrada ou
// saída, quantidade, usuário, observação) — só ganhou tenantId e as FKs
// reais da suíte que o sistema antigo não tinha.
// ═══════════════════════════════════════════════════════════════════════════

enum StockMovementType {
  ENTRADA
  SAIDA
}

model StockProduct {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  nome     String
  categoria String // livre no sistema antigo (LIMPEZA, LAVANDERIA, AMENITIES, EPI, ...) — sem enum aqui de propósito, pra não travar cadastro de categoria nova
  unidade  String @default("un")

  quantidade    Float @default(0) // saldo atual — atualizado a cada StockMovement, não recalculado on-the-fly (mesmo padrão do sistema antigo)
  estoqueMinimo Float @default(0)

  custo      Float?
  fornecedor String?

  ativo Boolean @default(true) // soft delete — produto com histórico de movimentação nunca é apagado de verdade

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  movements StockMovement[]
  menuItems MenuItem[]

  @@index([tenantId])
}

model StockMovement {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  productId String
  product   StockProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  tipo       StockMovementType
  quantidade Float

  // Free-text + FK opcional: dado migrado do sistema antigo tem "usuário"
  // como texto livre e inconsistente ("Milena ", "CAMILA", "Sistema",
  // "Responsável" — não bate com nenhum User real da suíte). Movimentos
  // novos, criados logado, preenchem os dois (nome vira um snapshot
  // estável mesmo se o usuário for renomeado/desativado depois).
  usuarioId   String?
  usuarioNome String
  usuario     User?   @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  observacao String?

  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([productId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Restaurante — cardápio de café da manhã por link público + kanban da cozinha.
// Integrado ao Estoque: todo MenuItem referencia um StockProduct, e a
// finalização de um pedido gera StockMovement de SAIDA por item (a fração
// quantidadePorPorcao permite que uma porção consuma menos de 1 unidade de
// estoque — ex.: porção de geleia = 0.1 do pote).
// ─────────────────────────────────────────────────────────────────────────────

model MenuSection {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  nome  String
  ordem Int    @default(0)
  // Limite de itens que o cliente pode escolher nesta seção num café
  // SINGLE. No DOUBLE o limite dobra (2x) — regra fixa do produto.
  limiteSingle Int @default(2)

  ativo Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items MenuItem[]

  @@index([tenantId])
}

model MenuItem {
  id        String      @id @default(cuid())
  tenantId  String
  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sectionId String
  section   MenuSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  nome      String
  descricao String?
  ordem     Int     @default(0)

  // Todo item do cardápio é obrigatoriamente um produto do Estoque —
  // não existe item "solto". quantidadePorPorcao é quanto do StockProduct
  // uma porção servida consome (1 = uma unidade inteira, 0.1 = um décimo).
  stockProductId      String
  stockProduct        StockProduct @relation(fields: [stockProductId], references: [id], onDelete: Cascade)
  quantidadePorPorcao Float        @default(1)

  ativo Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems BreakfastOrderItem[]

  @@index([tenantId])
  @@index([sectionId])
}

model BreakfastOrder {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Token do link público enviado ao hóspede — a rota /pedido/[token] não
  // exige sessão; o token (cuid + sufixo aleatório) é a própria credencial.
  token String @unique

  clienteNome String
  uhNumero    String
  tipo        String // SINGLE | DOUBLE

  // Fluxo: o Atendimento gera o link (status LINK_ENVIADO, fora do kanban);
  // quando o hóspede confirma o pedido vira RECEBIDO e entra na coluna 1.
  // Kanban: RECEBIDO → PREPARACAO → ENTREGA → FINALIZADO.
  // A baixa de estoque acontece UMA vez, na transição pra FINALIZADO
  // (estoqueBaixadoEm marca isso e impede dupla baixa).
  status String @default("LINK_ENVIADO")

  observacoes     String?
  horarioEntrega  String? // "07:00" | "07:30" | ... | "10:00"
  confirmadoEm    DateTime?
  estoqueBaixadoEm DateTime?

  criadoPorNome String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  itens BreakfastOrderItem[]

  @@index([tenantId, status])
}

model BreakfastOrderItem {
  id      String         @id @default(cuid())
  orderId String
  order   BreakfastOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  quantidade Int @default(1)

  @@unique([orderId, menuItemId])
}
